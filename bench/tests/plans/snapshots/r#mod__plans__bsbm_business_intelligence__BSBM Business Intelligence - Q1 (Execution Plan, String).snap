        HashJoinExec: mode=CollectLeft, join_type=Inner, on=[(reviewer@4, reviewer@0)], projection=[productType@0, review@3]
          HashJoinExec: mode=CollectLeft, join_type=Inner, on=[(review@3, review@0)], projection=[productType@0, product@1, producer@2, review@3, reviewer@5]
