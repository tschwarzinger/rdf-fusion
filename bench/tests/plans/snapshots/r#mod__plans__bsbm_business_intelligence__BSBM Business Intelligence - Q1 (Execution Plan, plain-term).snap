                  FilterExec: DynamicFilter [ product@0 >= {term_type:0,value:http://www4.wiwiss.fu-berlin.de/bizer/bsbm/v01/instances/dataFromProducer1/Product1,data_type:,language_tag:} AND product@0 <= {term_type:0,value:http://www4.wiwiss.fu-berlin.de/bizer/bsbm/v01/instances/dataFromProducer9/Product451,data_type:,language_tag:} AND hash_lookup ]
