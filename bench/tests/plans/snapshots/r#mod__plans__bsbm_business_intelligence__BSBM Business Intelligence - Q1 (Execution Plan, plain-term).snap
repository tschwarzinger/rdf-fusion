ProjectionExec: expr=[productType@0 as productType, ENC_PT(reviewCount@1) as reviewCount]
  SortExec: TopK(fetch=10), expr=[ENC_SORT(reviewCount@1) DESC, ENC_SORT(ENC_TF(productType@0)) ASC], preserve_partitioning=[false], filter=[ENC_SORT(reviewCount@1) IS NULL OR ENC_SORT(reviewCount@1) > {type:4,numeric:10.0,bytes:3130} OR ENC_SORT(reviewCount@1) = {type:4,numeric:10.0,bytes:3130} AND (ENC_SORT(ENC_TF(productType@0)) IS NULL OR ENC_SORT(ENC_TF(productType@0)) < {type:2,numeric:,bytes:687474703a2f2f777777342e7769776973732e66752d6265726c696e2e64652f62697a65722f6273626d2f7630312f696e7374616e6365732f50726f64756374547970653130})]
