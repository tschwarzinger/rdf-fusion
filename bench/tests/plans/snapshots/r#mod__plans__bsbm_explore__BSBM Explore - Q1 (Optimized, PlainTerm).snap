    Aggregate: groupBy=[[__common_expr_1 AS ENC_SORT(ENC_TF(label)), product]], aggr=[[first_value(product) ORDER BY [__common_expr_1 AS ENC_SORT(ENC_TF(label)) ASC NULLS FIRST, product ASC NULLS FIRST] AS first_value(product) ORDER BY [ENC_SORT(ENC_TF(label)) ASC NULLS FIRST, product ASC NULLS FIRST], first_value(label) ORDER BY [__common_expr_1 AS ENC_SORT(ENC_TF(label)) ASC NULLS FIRST, product ASC NULLS FIRST] AS first_value(label) ORDER BY [ENC_SORT(ENC_TF(label)) ASC NULLS FIRST, product ASC NULLS FIRST]]]
      Projection: ENC_SORT(ENC_TF(label)) AS __common_expr_1, product, label
        Sort: ENC_SORT(ENC_TF(label)) ASC NULLS FIRST
          Projection: lhs.product AS product, lhs.label AS label
            Inner Join: lhs.product = rhs.product
              SubqueryAlias: lhs
                Projection: lhs.product AS product, lhs.label AS label
                  Inner Join: lhs.product = rhs.product
                    SubqueryAlias: lhs
