Projection: ENC_PT(first_value(product) ORDER BY [AS_SORTABLE_BYTES(ENC_TF(ENC_PT(productLabel))) ASC NULLS FIRST, product ASC NULLS FIRST]) AS product, ENC_PT(first_value(productLabel) ORDER BY [AS_SORTABLE_BYTES(ENC_TF(ENC_PT(productLabel))) ASC NULLS FIRST, product ASC NULLS FIRST]) AS productLabel
  Sort: AS_SORTABLE_BYTES(ENC_TF(ENC_PT(productLabel))) ASC NULLS FIRST, product ASC NULLS FIRST, fetch=5
    Aggregate: groupBy=[[__common_expr_1 AS AS_SORTABLE_BYTES(ENC_TF(ENC_PT(productLabel))), product]], aggr=[[first_value(product) ORDER BY [__common_expr_1 AS AS_SORTABLE_BYTES(ENC_TF(ENC_PT(productLabel))) ASC NULLS FIRST, product ASC NULLS FIRST] AS first_value(product) ORDER BY [AS_SORTABLE_BYTES(ENC_TF(ENC_PT(productLabel))) ASC NULLS FIRST, product ASC NULLS FIRST], first_value(productLabel) ORDER BY [__common_expr_1 AS AS_SORTABLE_BYTES(ENC_TF(ENC_PT(productLabel))) ASC NULLS FIRST, product ASC NULLS FIRST] AS first_value(productLabel) ORDER BY [AS_SORTABLE_BYTES(ENC_TF(ENC_PT(productLabel))) ASC NULLS FIRST, product ASC NULLS FIRST]]]
      Projection: AS_SORTABLE_BYTES(ENC_TF(ENC_PT(productLabel))) AS __common_expr_1, product, productLabel
        Sort: AS_SORTABLE_BYTES(ENC_TF(ENC_PT(productLabel))) ASC NULLS FIRST
          BasicGraphPattern: filters=[product != Utf8("<http://www4.wiwiss.fu-berlin.de/bizer/bsbm/v01/instances/dataFromProducer19/Product890>") AND EBV(LT(ENC_TF(ENC_PT(simProperty1)), ADD(ENC_TF(ENC_PT(origProperty1)), Union 4:4:120))) AND EBV(GT(ENC_TF(ENC_PT(simProperty1)), SUB(ENC_TF(ENC_PT(origProperty1)), Union 4:4:120))) AND EBV(LT(ENC_TF(ENC_PT(simProperty2)), ADD(ENC_TF(ENC_PT(origProperty2)), Union 4:4:170))) AND EBV(GT(ENC_TF(ENC_PT(simProperty2)), SUB(ENC_TF(ENC_PT(origProperty2)), Union 4:4:170))) AS EBV(BOOLEAN_AS_TERM(EBV(BOOLEAN_AS_TERM(EBV(BOOLEAN_AS_TERM(NOT EBV(EQ(ENC_TF(Struct({term_type:0,value:http://www4.wiwiss.fu-berlin.de/bizer/bsbm/v01/instances/dataFromProducer19/Product890,data_type:,language_tag:})),ENC_TF(ENC_PT(product)))))) AND EBV(BOOLEAN_AS_TERM(EBV(LT(ENC_TF(ENC_PT(simProperty1)),ADD(ENC_TF(ENC_PT(origProperty1)),ENC_TF(Struct({term_type:2,value:120,data_type:http://www.w3.org/2001/XMLSchema#integer,language_tag:}))))) AND EBV(GT(ENC_TF(ENC_PT(simProperty1)),SUB(ENC_TF(ENC_PT(origProperty1)),ENC_TF(Struct({term_type:2,value:120,data_type:http://www.w3.org/2001/XMLSchema#integer,language_tag:}))))))))) AND EBV(BOOLEAN_AS_TERM(EBV(LT(ENC_TF(ENC_PT(simProperty2)),ADD(ENC_TF(ENC_PT(origProperty2)),ENC_TF(Struct({term_type:2,value:170,data_type:http://www.w3.org/2001/XMLSchema#integer,language_tag:}))))) AND EBV(GT(ENC_TF(ENC_PT(simProperty2)),SUB(ENC_TF(ENC_PT(origProperty2)),ENC_TF(Struct({term_type:2,value:170,data_type:http://www.w3.org/2001/XMLSchema#integer,language_tag:})))))))))], projection=[Column { relation: None, name: "product" }, Column { relation: None, name: "productLabel" }], 
