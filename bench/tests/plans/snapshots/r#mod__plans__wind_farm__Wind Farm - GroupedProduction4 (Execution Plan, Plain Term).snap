---
source: bench/tests/plans/wind_farm.rs
expression: "&string"
---
ProjectionExec: expr=[site_label@0 as site_label, wtur_label@1 as wtur_label, year@2 as year, month@3 as month, day@4 as day, hour@5 as hour, minute_10@6 as minute_10, ENC_PT(<uuid>@7) as avg_val]
  AggregateExec: mode=Single, gby=[site_label@0 as site_label, wtur_label@1 as wtur_label, ENC_PT(year@7) as year, ENC_PT(month@6) as month, ENC_PT(day@5) as day, ENC_PT(hour@4) as hour, ENC_PT(minute_10@3) as minute_10], aggr=[<uuid>]
    ProjectionExec: expr=[site_label@1 as site_label, wtur_label@2 as wtur_label, val@3 as val, minute_10@4 as minute_10, hour@5 as hour, day@6 as day, MONTH(__common_expr_2@0) as month, YEAR(__common_expr_2@0) as year]
      ProjectionExec: expr=[ENC_TF(t@4) as __common_expr_2, site_label@1 as site_label, wtur_label@2 as wtur_label, val@3 as val, MUL(4:4:10, FLOOR(DIV(MINUTES(__common_expr_5@0), 4:2:Some(<uuid>),36,18))) as minute_10, HOURS(__common_expr_5@0) as hour, DAY(__common_expr_5@0) as day]
        ProjectionExec: expr=[ENC_TF(t@3) as __common_expr_5, site_label@0 as site_label, wtur_label@1 as wtur_label, val@2 as val, t@3 as t]
          HashJoinExec: mode=CollectLeft, join_type=Inner, on=[(dp@2, dp@0)], projection=[site_label@0, wtur_label@1, val@3, t@5]
            HashJoinExec: mode=CollectLeft, join_type=Inner, on=[(dp@2, dp@0)], projection=[site_label@0, wtur_label@1, dp@2, val@4]
              HashJoinExec: mode=CollectLeft, join_type=Inner, on=[(ts@2, ts@0)], projection=[site_label@0, wtur_label@1, dp@4]
                HashJoinExec: mode=CollectLeft, join_type=Inner, on=[(ts@2, ts@0)], projection=[site_label@0, wtur_label@1, ts@2]
                  HashJoinExec: mode=CollectLeft, join_type=Inner, on=[(generator@2, generator@0)], projection=[site_label@0, wtur_label@1, ts@4]
                    HashJoinExec: mode=CollectLeft, join_type=Inner, on=[(generator@2, generator@0)], projection=[site_label@0, wtur_label@1, generator@2]
                      HashJoinExec: mode=CollectLeft, join_type=Inner, on=[(generator_asp@2, generator_asp@1)], projection=[site_label@0, wtur_label@1, generator@3]
                        HashJoinExec: mode=CollectLeft, join_type=Inner, on=[(gensys@2, gensys@0)], projection=[site_label@0, wtur_label@1, generator_asp@4]
                          HashJoinExec: mode=CollectLeft, join_type=Inner, on=[(gensys@2, gensys@0)], projection=[site_label@0, wtur_label@1, gensys@2]
                            HashJoinExec: mode=CollectLeft, join_type=Inner, on=[(gensys_asp@2, gensys_asp@1)], projection=[site_label@0, wtur_label@1, gensys@3]
                              HashJoinExec: mode=CollectLeft, join_type=Inner, on=[(wtur@2, wtur@0)], projection=[site_label@0, wtur_label@1, gensys_asp@3]
                                HashJoinExec: mode=CollectLeft, join_type=Inner, on=[(wtur@2, wtur@0)], projection=[site_label@0, wtur_label@1, wtur@2, gensys_asp@4]
                                  HashJoinExec: mode=CollectLeft, join_type=Inner, on=[(wtur_asp@1, wtur_asp@1)], projection=[site_label@0, wtur_label@2, wtur@3]
                                    HashJoinExec: mode=CollectLeft, join_type=Inner, on=[(wtur_asp@1, wtur_asp@0)], projection=[site_label@0, wtur_asp@1, wtur_label@3]
                                      HashJoinExec: mode=CollectLeft, join_type=Inner, on=[(site@0, site@0)], projection=[site_label@1, wtur_asp@3]
                                        HashJoinExec: mode=CollectLeft, join_type=Inner, on=[(site@0, site@0)], projection=[site@0, site_label@2]
                                          DeltaQuadStorageScanExec: index=GPOS, active_graph=Default Graph, triple_pattern=[?site <http://www.w3.org/1999/02/22-rdf-syntax-ns#type> <https://github.com/magbak/chrontext/rds_power#Site>], blank_node_mode=Variable
                                          FilterExec: DynamicFilter [ site@0 >= {term_type:0,value:https://github.com/magbak/chrontext/windpower_example#Site1,data_type:,language_tag:} AND site@0 <= {term_type:0,value:https://github.com/magbak/chrontext/windpower_example#Site4,data_type:,language_tag:} AND site@0 IN (SET) ([{term_type:0,value:https://github.com/magbak/chrontext/windpower_example#Site1,data_type:,language_tag:}, {term_type:0,value:https://github.com/magbak/chrontext/windpower_example#Site2,data_type:,language_tag:}, {term_type:0,value:https://github.com/magbak/chrontext/windpower_example#Site3,data_type:,language_tag:}, {term_type:0,value:https://github.com/magbak/chrontext/windpower_example#Site4,data_type:,language_tag:}]) ]
                                            DeltaQuadStorageScanExec: index=GPOS, active_graph=Default Graph, triple_pattern=[?site <http://www.w3.org/2000/01/rdf-schema#label> ?site_label], blank_node_mode=Variable, pushed_filters=[DynamicFilter [ site@0 >= {term_type:0,value:https://github.com/magbak/chrontext/windpower_example#Site1,data_type:,language_tag:} AND site@0 <= {term_type:0,value:https://github.com/magbak/chrontext/windpower_example#Site4,data_type:,language_tag:} AND site@0 IN (SET) ([{term_type:0,value:https://github.com/magbak/chrontext/windpower_example#Site1,data_type:,language_tag:}, {term_type:0,value:https://github.com/magbak/chrontext/windpower_example#Site2,data_type:,language_tag:}, {term_type:0,value:https://github.com/magbak/chrontext/windpower_example#Site3,data_type:,language_tag:}, {term_type:0,value:https://github.com/magbak/chrontext/windpower_example#Site4,data_type:,language_tag:}]) ]]
                                        FilterExec: DynamicFilter [ site@0 >= {term_type:0,value:https://github.com/magbak/chrontext/windpower_example#Site1,data_type:,language_tag:} AND site@0 <= {term_type:0,value:https://github.com/magbak/chrontext/windpower_example#Site4,data_type:,language_tag:} AND site@0 IN (SET) ([{term_type:0,value:https://github.com/magbak/chrontext/windpower_example#Site4,data_type:,language_tag:}, {term_type:0,value:https://github.com/magbak/chrontext/windpower_example#Site2,data_type:,language_tag:}, {term_type:0,value:https://github.com/magbak/chrontext/windpower_example#Site3,data_type:,language_tag:}, {term_type:0,value:https://github.com/magbak/chrontext/windpower_example#Site1,data_type:,language_tag:}]) ]
