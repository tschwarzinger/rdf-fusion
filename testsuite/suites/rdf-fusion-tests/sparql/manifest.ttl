@prefix rdf:   <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix :      <https://codeberg.org/tschwarzinger/rdf-fusion/raw/branch/main/testsuite/rdf-fusion-tests/sparql/manifest.ttl#> .
@prefix rdfs:  <http://www.w3.org/2000/01/rdf-schema#> .
@prefix mf:    <http://www.w3.org/2001/sw/DataAccess/tests/test-manifest#> .
@prefix qt:    <http://www.w3.org/2001/sw/DataAccess/tests/test-query#> .
@prefix ut:    <http://www.w3.org/2009/sparql/tests/test-update#> .

<>  rdf:type mf:Manifest ;
    rdfs:label "RDF Fusion SPARQL tests" ;
    mf:entries
    (
        :complex_expression_in_order_by
        # :zorder_test ZOrder is currently not supported in SPARQL
    ) .

:complex_expression_in_order_by rdf:type mf:QueryEvaluationTest ;
    mf:name "A SPARQL query with a complex expression in the ORDER BY clause" ;
    mf:action
         [ qt:query  <complex_expression_in_order_by.rq> ;
           qt:data   <complex_expression_in_order_by.ttl> ] ;
    mf:result  <complex_expression_in_order_by.srx> .

:zorder_test rdf:type mf:QueryEvaluationTest ;
    mf:name "A SPARQL query with ZOrder function in ORDER BY" ;
    mf:action
         [ qt:query  <zorder_test.rq> ;
           qt:data   <zorder_test.ttl> ] ;
    mf:result  <zorder_test.srx> .
